componentsStructure/
  └── {componentType}.ts                  ← Structure & fields

components/tenant/{componentType}/
  └── {componentType}1.tsx                ← React component
```

### **Store Files:**
```
context/
  ├── editorStore.ts                      ← Main store
  ├── tenantStore.jsx                     ← Tenant data
  └── editorI18nStore.ts                  ← Translations
